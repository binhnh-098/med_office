SPRING_PROFILES_ACTIVE=prod
PORT=8080

MED_OFFICE_DB_URL=jdbc:mysql://localhost:3306/med_office?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
MED_OFFICE_DB_USERNAME=med_office
MED_OFFICE_DB_PASSWORD=change_me

CORS_ALLOWED_ORIGINS=http://192.168.54.100:5173
# Or use patterns when your frontend host changes often inside a LAN:
# CORS_ALLOWED_ORIGIN_PATTERNS=http://192.168.*:5173,http://10.*:5173
SPRINGDOC_ENABLED=false

# Raw IP + HTTP deployment
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

AI_PROVIDER=nvidia
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=
AI_MODEL=meta/llama-3.1-70b-instruct
AI_MOCK_ON_ERROR=false
AI_CONNECT_TIMEOUT=5s
AI_TIMEOUT_MS=30s
AI_MAX_TOKENS=512
