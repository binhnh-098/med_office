[Unit]
Description=Med Office Backend
After=network.target mysql.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/med_office
EnvironmentFile=/home/ubuntu/med_office/.env
ExecStart=/usr/bin/java -jar /home/ubuntu/med_office/target/med_office-0.0.1-SNAPSHOT.jar
SuccessExitStatus=143
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
